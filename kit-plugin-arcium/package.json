  },
  "devDependencies": {
    "@solana/kit": "^5.4.0",
    "@types/node": "^22.0.0",
    "solana-kite": "^3.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.7.1"
  }
