{
  "name": "kit-plugin-arcium",
  "version": "0.1.0",
  "description": "Arcium confidential computing plugin for Solana Kit (layers on the Kite capability)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/arcium.json dist/",
    "test": "tsx --test src/**/*.test.ts",
    "prepublishOnly": "npm run build",
    "test:ci": "tsx --test src/**/*.unit.test.ts"
  },
  "keywords": [
    "solana",
    "kit",
    "kite",
    "arcium",
    "confidential-computing",
    "mpc",
    "plugin"
  ],
  "license": "MIT",
  "peerDependencies": {
    "solana-kite": "^3.2.0",
    "@solana/kit": "^6.0.0"
  },
  "devDependencies": {
    "@solana/kit": "^6.9.0",
    "@types/node": "^22.0.0",
    "solana-kite": "^3.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.7.1"
  }
}
