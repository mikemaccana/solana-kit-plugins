{
  "name": "solana-kite-arcium",
  "version": "0.1.0",
  "description": "Arcium confidential computing plugin for Solana Kite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
