{
  "name": "kit-plugin-pyth",
  "version": "0.1.0",
  "description": "Pyth Network oracle plugin for Solana Kit - price feeds via Hermes API and on-chain price accounts (layers on the Kite capability)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test src/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "kit",
    "kite",
    "pyth",
    "oracle",
    "price-feed",
    "hermes",
    "defi"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "solana-kite": "^3.2.0",
    "@solana/kit": "^6.0.0"
  },
  "devDependencies": {
    "@solana/kit": "^6.9.0",
    "@types/node": "^22.10.5",
    "solana-kite": "^3.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {}
}
