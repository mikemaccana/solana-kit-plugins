{
  "name": "kit-plugin-squads-multisig",
  "version": "0.1.0",
  "description": "Squads multisig plugin for Solana Kit - web3.js-free multisig wallet management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test src/**/*.test.ts",
    "prepublishOnly": "npm run build",
    "test:ci": "tsx --test src/**/*.unit.test.ts",
    "generate": "node codama.js",
    "test:litesvm": "tsx --test src/**/*.litesvm.test.ts"
  },
  "keywords": [
    "solana",
    "kit",
    "kite",
    "squads",
    "multisig",
    "wallet",
    "treasury",
    "dao"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "solana-kite": "^3.2.0",
    "@solana/kit": "^6.0.0"
  },
  "devDependencies": {
    "@solana/kit": "^6.9.0",
    "@types/node": "^22.10.5",
    "solana-kite": "^3.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "codama": "^1.7.0",
    "@codama/nodes-from-anchor": "^1.5.0",
    "@codama/renderers-js": "^2.2.0",
    "kit-plugin-litesvm": "file:../kit-plugin-litesvm"
  },
  "dependencies": {}
}
