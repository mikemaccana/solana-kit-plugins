    "kite",
    "tuktuk",
    "scheduler",
    "cron",
    "automation",
    "web3"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "solana-kite": "^3.0.0",
    "@solana/kit": "^5.0.0"
  },
  "devDependencies": {
    "@solana/kit": "^5.4.0",
    "@types/node": "^22.10.5",
    "solana-kite": "^3.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@solana-program/system": "^0.10.0"
  }
}
